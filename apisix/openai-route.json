{
  "id": "provider-openai-chat",
  "uri": "/v1/providers/openai/chat",
  "methods": ["POST"],
  "plugins": {
    "key-auth": {},
    "proxy-rewrite": {
      "uri": "/v1/responses",
      "headers": {
        "set": {
          "Authorization": "Bearer $OPENAI_API_KEY"
        },
        "remove": ["apikey"]
      }
    }
  },
  "upstream": {
    "type": "roundrobin",
    "scheme": "https",
    "nodes": {
      "api.openai.com:443": 1
    },
    "pass_host": "node"
  }
}