{
  "id": "anthropic-messages",
  "uri": "/v1/messages",
  "methods": ["POST"],
  "plugins": {
    "serverless-pre-function": {
      "phase": "rewrite",
      "functions": [
        "return function(conf, ctx) local auth = require('apisix.plugins.auth-transform') return auth.bearer_to_api_key(conf, ctx) end"
      ]
    },
    "key-auth": {
      "header": "x-api-key",
      "hide_credentials": true
    },
    "proxy-rewrite": {
      "headers": {
        "remove": [
          "Origin",
          "Referer",
          "Cookie",
          "Sec-Fetch-Site",
          "Sec-Fetch-Mode",
          "Sec-Fetch-Dest"
        ],
        "set": {
          "x-api-key": "$ANTHROPIC_API_KEY"
        }
      }
    }
  },
  "upstream": {
    "type": "roundrobin",
    "scheme": "https",
    "nodes": {
      "api.anthropic.com:443": 1
    },
    "pass_host": "node"
  }
}