{
  "id": "provider-litellm-chat",
  "uri": "/v1/providers/litellm/chat",
  "methods": ["POST"],
  "plugins": {
    "key-auth": {},
    "proxy-rewrite": {
      "uri": "/v1/chat/completions",
      "headers": {
        "set": {
          "Authorization": "Bearer $LITELLM_KEY"
        },
        "remove": ["apikey"]
      }
    }
  },
  "upstream": {
    "type": "roundrobin",
    "scheme": "https",
    "nodes": {
      "anast.ita.chalmers.se:4000": 1
    },
    "pass_host": "node"
  }
}