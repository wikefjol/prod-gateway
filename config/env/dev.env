# Docker Compose Environment Variables - Development Environment
# Used with: docker compose -p apisix-dev --env-file config/env/dev.env

# Host Port Mappings for Dev Environment
APISIX_HOST_GATEWAY_PORT=9080
APISIX_HOST_ADMIN_PORT=9180

# Environment Configuration
ENVIRONMENT=dev

# Docker User/Group Configuration
HOST_UID=364274
HOST_GID=364274