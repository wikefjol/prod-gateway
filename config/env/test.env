# Docker Compose Environment Variables - Test Environment
# Used with: docker compose -p apisix-test --env-file config/env/test.env

# Host Port Mappings for Test Environment (Different from Dev)
APISIX_HOST_GATEWAY_PORT=9081
APISIX_HOST_ADMIN_PORT=9181

# Environment Configuration
ENVIRONMENT=test

# Docker User/Group Configuration
HOST_UID=364274
HOST_GID=364274