# EntraID OIDC Provider Configuration - Test Environment

# Provider Identity
OIDC_PROVIDER_NAME=entraid

# OIDC Configuration (using secrets from secrets/entraid-test.env)
OIDC_CLIENT_ID=${ENTRAID_CLIENT_ID}
OIDC_CLIENT_SECRET=${ENTRAID_CLIENT_SECRET}
OIDC_DISCOVERY_ENDPOINT=https://login.microsoftonline.com/${ENTRAID_TENANT_ID}/v2.0/.well-known/openid-configuration
OIDC_SESSION_SECRET=${ENTRAID_SESSION_SECRET}

# Redirect Configuration - Test Environment (Public)
OIDC_REDIRECT_URI=https://ai-gateway.portal.chalmers.se/portal/callback
OIDC_SCOPE="openid profile email"

# Portal Backend Configuration - Service name only (compose project separation)
PORTAL_BACKEND_HOST=portal-backend:3000
PORTAL_BACKEND_PORT=3001

# Legacy Azure AD Variables (for backward compatibility with existing bootstrap scripts)
AZURE_CLIENT_ID=${ENTRAID_CLIENT_ID}
AZURE_CLIENT_SECRET=${ENTRAID_CLIENT_SECRET}
AZURE_TENANT_ID=${ENTRAID_TENANT_ID}
REDIRECT_URI=${OIDC_REDIRECT_URI}
BACKEND_HOST=portal-backend:3000

# EntraID Specific Settings
ENTRAID_AUTHORITY=https://login.microsoftonline.com/${ENTRAID_TENANT_ID}
ENTRAID_ISSUER=https://login.microsoftonline.com/${ENTRAID_TENANT_ID}/v2.0