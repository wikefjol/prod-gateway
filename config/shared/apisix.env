# APISIX Admin Keys and Security Configuration
# These reference secrets from secrets/ directory (single source of truth)

# APISIX Admin/Viewer Keys (from secrets)
ADMIN_KEY=${ADMIN_KEY}
VIEWER_KEY=${VIEWER_KEY}

# APISIX Admin API Configuration
APISIX_ADMIN_API=http://localhost:9180/apisix/admin
APISIX_ADMIN_API_CONTAINER=http://apisix:${APISIX_ADMIN_PORT:-9180}/apisix/admin

# Admin UI is built into APISIX (enable_admin_ui: true in config)
APISIX_ADMIN_UI_ENABLED=true