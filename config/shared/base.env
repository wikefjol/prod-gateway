# APISIX Gateway Base Configuration
# Common variables shared across all environments and providers

# APISIX Core Configuration
APISIX_PROFILE=dev
APISIX_NODE_LISTEN=9080
APISIX_ADMIN_PORT=9180

# Host Port Mappings (Docker Compose Projects)
# Override these in config/env/{environment}.env for different environments
APISIX_HOST_GATEWAY_PORT=9080
APISIX_HOST_ADMIN_PORT=9180

# Development APISIX API Endpoints
APISIX_ADMIN_API=http://localhost:9180/apisix/admin
ADMIN_API=http://localhost:9180/apisix/admin
DATA_PLANE=http://localhost:9080

# etcd Configuration (Docker Compose Projects)
ETCD_HOST=http://etcd:2379

# Docker Configuration
# UID=364274  # Note: UID is often readonly, set via docker-compose environment
GID=364274

# Environment Settings
ENVIRONMENT=dev
CUSTOM_PROFILE=dev

# AI Provider API Keys
# These are now sourced from secrets/{provider}-{environment}.env files
# No hardcoded secrets in shared configuration