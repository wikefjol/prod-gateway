# APISIX Gateway Test Environment Configuration
# Test environment overrides for shared configuration

# Test Environment Profile
APISIX_PROFILE=test
ENVIRONMENT=test
CUSTOM_PROFILE=test

# APISIX Core Configuration - Container ports stay consistent
APISIX_NODE_LISTEN=9080
APISIX_ADMIN_PORT=9180

# Test Environment etcd Configuration - Service name only (compose project separation)
ETCD_HOST=http://etcd:2379

# Test Environment APISIX API Endpoints - Container endpoint for portal backend access
APISIX_ADMIN_API_CONTAINER=http://apisix:${APISIX_ADMIN_PORT:-9180}/apisix/admin

# Note: APISIX_ADMIN_API remains as localhost for external tooling
# Note: Central services keys inherited from base.env (LITELLM_KEY, ANTHROPIC_API_KEY, OPENAI_API_KEY)
# Note: ADMIN_KEY and VIEWER_KEY inherited from apisix.env