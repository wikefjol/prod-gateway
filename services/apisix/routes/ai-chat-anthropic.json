{
  "id": "ai-chat-anthropic",
  "name": "ai-chat-anthropic",
  "uri": "/ai/v1/chat/completions",
  "methods": ["POST"],
  "priority": 10,
  "vars": [["post_arg.model", "~~", "^claude"]],
  "plugins": {
    "serverless-pre-function": {
      "_meta": { "priority": 12020 },
      "phase": "rewrite",
      "functions": [
        "return function(conf, ctx) local auth = require('apisix.plugins.auth-transform') auth.sanitize_request_ids(conf, ctx) return auth.bearer_to_api_key(conf, ctx) end"
      ]
    },
    "key-auth": {
      "header": "x-api-key",
      "hide_credentials": true
    },
    "request-id": {
      "header_name": "X-Request-Id",
      "include_in_response": true
    },
    "ai-proxy": {
      "provider": "anthropic",
      "auth": {
        "header": {
          "x-api-key": "$ANTHROPIC_API_KEY",
          "anthropic-version": "2023-06-01"
        }
      }
    },
    "file-logger": {
      "path": "/var/log/apisix/billing/ai-chat.log"
    }
  }
}
