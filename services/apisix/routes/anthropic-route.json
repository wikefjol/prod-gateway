{
  "id": "provider-anthropic-chat",
  "uri": "/v1/providers/anthropic/chat",
  "methods": ["POST"],
  "plugins": {
    "key-auth": {
      "header": "X-Gateway-Key",
      "hide_credentials": true
      },
    "proxy-rewrite": {
      "uri": "/v1/messages",
      "headers": {
        "remove": [
          "Origin",
          "Referer",
          "Cookie",
          "Sec-Fetch-Site",
          "Sec-Fetch-Mode",
          "Sec-Fetch-Dest"
        ],
        "set": {
          "x-api-key": "$ANTHROPIC_API_KEY",
          "anthropic-version": "2023-06-01"
        }
      }
    }
  },
  "upstream": {
    "type": "roundrobin",
    "scheme": "https",
    "nodes": {
      "api.anthropic.com:443": 1
    },
    "pass_host": "node"
  }
}