{
  "id": "provider-litellm-chat",
  "uri": "/v1/providers/litellm/chat",
  "methods": ["POST"],
  "plugins": {
    "key-auth": {
    "header": "X-Gateway-Key",
    "hide_credentials": true
    },
    "proxy-rewrite": {
      "uri": "/v1/chat/completions",
      "headers": {
        "remove": [
          "Origin",
          "Referer",
          "Cookie",
          "Sec-Fetch-Site",
          "Sec-Fetch-Mode",
          "Sec-Fetch-Dest"
        ],
        "set": {
          "Authorization": "Bearer $LITELLM_KEY"
        }
      }
    }
  },
  "upstream": {
    "type": "roundrobin",
    "scheme": "https",
    "nodes": {
      "anast.ita.chalmers.se:4000": 1
    },
    "pass_host": "node"
  }
}