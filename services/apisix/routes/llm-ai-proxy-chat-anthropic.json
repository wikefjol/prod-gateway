{
  "id": "llm-ai-proxy-chat-anthropic",
  "name": "llm-ai-proxy-chat-anthropic",
  "uri": "/llm/ai-proxy/v1/chat/completions",
  "methods": ["POST", "OPTIONS"],
  "priority": 10,
  "vars": [["post_arg.model", "~~", "^claude"]],
  "plugins": {
    "cors": {
      "allow_origins": "*",
      "allow_methods": "POST,OPTIONS",
      "allow_headers": "Authorization,Content-Type,X-Request-Id",
      "expose_headers": "X-Request-Id",
      "max_age": 3600
    },
    "auth-transform": {
      "mode": "bearer_to_api_key",
      "sanitize_request_ids": true
    },
    "openai-auth": {
      "header": "x-api-key",
      "hide_credentials": true
    },
    "model-policy": {
      "action": "enforce"
    },
    "request-id": {
      "header_name": "X-Request-Id",
      "include_in_response": true
    },
    "ai-proxy": {
      "provider": "anthropic",
      "auth": {
        "header": {
          "x-api-key": "$ANTHROPIC_API_KEY",
          "anthropic-version": "2023-06-01"
        }
      }
    },
    "provider-response-id": {},
    "file-logger": {
      "path": "/usr/local/apisix/logs/billing/llm-ai-proxy-chat.log"
    },
    "response-wiretap": {
      "enabled": true,
      "log_path": "/usr/local/apisix/logs/wiretap/llm-ai-proxy-chat.jsonl"
    }
  }
}
