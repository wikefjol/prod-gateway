{
  "id": "openwebui-direct",
  "name": "openwebui-direct",
  "uri": "/openwebui/direct/v1/*",
  "methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
  "plugins": {
    "serverless-pre-function": {
      "_meta": { "priority": 12020 },
      "phase": "rewrite",
      "functions": [
        "return function(conf, ctx) if ngx.req.get_method() == 'OPTIONS' then ngx.header['Access-Control-Allow-Origin'] = '*' ngx.header['Access-Control-Allow-Methods'] = 'GET,POST,PUT,DELETE,OPTIONS' ngx.header['Access-Control-Allow-Headers'] = 'Authorization,Content-Type,X-Request-Id' ngx.header['Access-Control-Max-Age'] = '3600' ngx.exit(204) end local auth = require('apisix.plugins.auth-transform') auth.sanitize_request_ids(conf, ctx) return auth.bearer_to_api_key(conf, ctx) end"
      ]
    },
    "cors": {
      "allow_origins": "*",
      "allow_methods": "GET,POST,PUT,DELETE,OPTIONS",
      "allow_headers": "Authorization,Content-Type,X-Request-Id",
      "expose_headers": "X-Request-Id",
      "max_age": 3600,
      "allow_credential": false
    },
    "openai-auth": {
      "_meta": {
        "filter": [["request_method", "~=", "OPTIONS"]]
      },
      "header": "x-api-key",
      "hide_credentials": true
    },
    "proxy-rewrite": {
      "_meta": {
        "filter": [["request_method", "~=", "OPTIONS"]]
      },
      "regex_uri": ["^/openwebui/direct/v1/(.*)", "/v1/$1"],
      "headers": {
        "remove": ["Origin", "Referer", "Cookie", "Sec-Fetch-Site", "Sec-Fetch-Mode", "Sec-Fetch-Dest"],
        "set": {
          "Authorization": "Bearer $LITELLM_KEY"
        }
      }
    },
    "request-id": {
      "header_name": "X-Request-Id",
      "include_in_response": true
    },
    "billing-extractor": {
      "_meta": {
        "filter": [["request_method", "~=", "OPTIONS"]]
      },
      "provider": "openai",
      "endpoint": "passthrough"
    },
    "serverless-post-function": {
      "phase": "header_filter",
      "functions": [
        "return function(conf, ctx) local gw_id = ngx.req.get_headers()['X-Request-Id'] if gw_id then ngx.header['X-Request-Id'] = gw_id end end"
      ]
    },
    "kafka-logger": {
      "_meta": {
        "filter": [["request_method", "~=", "OPTIONS"]]
      },
      "brokers": [{"host": "kafka", "port": 9092}],
      "kafka_topic": "$KAFKA_TOPIC",
      "batch_max_size": 1,
      "include_req_body": false,
      "include_resp_body": false
    }
  },
  "upstream": {
    "type": "roundrobin",
    "scheme": "https",
    "nodes": {
      "anast.ita.chalmers.se:4000": 1
    },
    "pass_host": "node"
  }
}
