{
  "id": "provider-anthropic-count-tokens",
  "name": "provider-anthropic-count-tokens",
  "uri": "/provider/anthropic/v1/messages/count_tokens",
  "methods": ["POST"],
  "plugins": {
    "serverless-pre-function": {
      "_meta": { "priority": 12020 },
      "phase": "rewrite",
      "functions": [
        "return function(conf, ctx) local auth = require('apisix.plugins.auth-transform') auth.sanitize_request_ids(conf, ctx) return auth.bearer_to_api_key(conf, ctx) end"
      ]
    },
    "key-auth": {
      "header": "x-api-key",
      "hide_credentials": true
    },
    "proxy-rewrite": {
      "uri": "/v1/messages/count_tokens",
      "headers": {
        "remove": ["Origin", "Referer", "Cookie", "Sec-Fetch-Site", "Sec-Fetch-Mode", "Sec-Fetch-Dest"],
        "set": {
          "x-api-key": "$ANTHROPIC_API_KEY",
          "anthropic-version": "2023-06-01"
        }
      }
    },
    "request-id": {
      "header_name": "X-Request-Id",
      "include_in_response": true
    }
  },
  "upstream": {
    "type": "roundrobin",
    "scheme": "https",
    "nodes": {
      "api.anthropic.com:443": 1
    },
    "pass_host": "node"
  }
}
