{
  "id": "provider-openai-responses",
  "name": "provider-openai-responses",
  "uri": "/provider/openai/v1/responses",
  "methods": ["POST"],
  "plugins": {
    "serverless-pre-function": {
      "_meta": { "priority": 12020 },
      "phase": "rewrite",
      "functions": [
        "return function(conf, ctx) local auth = require('apisix.plugins.auth-transform') auth.sanitize_request_ids(conf, ctx) return auth.bearer_to_api_key(conf, ctx) end"
      ]
    },
    "openai-auth": {
      "header": "x-api-key",
      "hide_credentials": true
    },
    "proxy-rewrite": {
      "uri": "/v1/responses",
      "headers": {
        "remove": ["Origin", "Referer", "Cookie", "Sec-Fetch-Site", "Sec-Fetch-Mode", "Sec-Fetch-Dest"],
        "set": {
          "Authorization": "Bearer $OPENAI_API_KEY",
          "Accept-Encoding": "identity"
        }
      }
    },
    "request-id": {
      "header_name": "X-Request-Id",
      "include_in_response": true
    },
    "billing-extractor": {
      "provider": "openai",
      "endpoint": "responses"
    },
    "serverless-post-function": {
      "phase": "header_filter",
      "functions": [
        "return function(conf, ctx) local gw_id = ngx.req.get_headers()['X-Request-Id'] if gw_id then ngx.header['X-Request-Id'] = gw_id end end"
      ]
    },
    "file-logger": {
      "path": "/var/log/apisix/billing/openai-responses.log"
    },
    "response-wiretap": {
      "always_capture": true,
      "log_path": "/var/log/apisix/wiretap/openai-responses.jsonl"
    }
  },
  "upstream": {
    "type": "roundrobin",
    "scheme": "https",
    "nodes": {
      "api.openai.com:443": 1
    },
    "pass_host": "node"
  }
}
